{
  "manifest_version": 3,
  "name": "Sonto",
  "version": "1.0.0",
  "description": "Your local second brain. Capture highlights, search your browsing history with AI.",
  "author": "Artem Iagovdik (artyom.yagovdik@gmail.com)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "contextMenus",
    "scripting",
    "offscreen",
    "history",
    "alarms"
  ],
  "host_permissions": [
    "*://*/*",
    "https://api.openai.com/*",
    "https://api.x.ai/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Open Sonto"
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Open Sonto sidebar"
    },
    "capture_selection": {
      "suggested_key": {
        "default": "Alt+Shift+C",
        "mac": "Alt+Shift+C"
      },
      "description": "Save selected text to Sonto"
    }
  },
  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  }
}
